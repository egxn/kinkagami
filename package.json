{
  "name": "kinkagami",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "setup": "pnpm install && cd backend && poetry install && cd .. && pnpm db:migrate",
    "configure": "bash ./setup/configure.sh",

    "dev": "vite",
    "dev:frontend": "bash ./setup/run-runtime.sh frontend",
    "dev:python": "bash ./setup/run-runtime.sh python",
    "dev:videos": "concurrently \"pnpm server:videos\" \"pnpm dev\"",
    "dev:stream": "concurrently \"bash ./setup/run-stream.sh\" \"pnpm dev\"",

    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "pnpm build && pnpm preview",
    "start:python": "cd backend && poetry run kgm-camera-backend & bash ./setup/wait-for-port.sh ${KGM_PYTHON_WS_HOST:-127.0.0.1} ${KGM_PYTHON_WS_PORT:-8765} && pnpm preview",

    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",

    "server:videos": "node server_videos.js",
    "db:migrate": "node scripts/db-seeds-load.mjs",
    "db:seeds:generate": "node scripts/db-seeds-generate.mjs",

    "kiosk": "chromium --kiosk --use-fake-ui-for-media-stream --autoplay-policy=no-user-gesture-required --noerrdialogs --disable-infobars --disable-session-crashed-bubble --disable-features=TranslateUI --start-fullscreen http://localhost:4173 --auto-open-devtools-for-tabs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mediapipe/pose": "^0.5.1675469404",
    "@tensorflow-models/hand-pose-detection": "^2.0.1",
    "@tensorflow-models/pose-detection": "^2.1.3",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-wasm": "^4.22.0",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
    "@tensorflow/tfjs-backend-webgpu": "^4.22.0",
    "@tensorflow/tfjs-converter": "^4.22.0",
    "@tensorflow/tfjs-core": "^4.22.0",
    "express": "^4.18.2",
    "pouchdb": "^9.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "seedrandom": "^3.0.5",
    "i18next": "^24.2.2",
    "react-i18next": "^15.4.0",
    "i18next-browser-languagedetector": "^8.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/pouchdb": "^6.4.2",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "concurrently": "^9.0.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "sass": "^1.97.3",
    "jsdom": "^26.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^3.2.4"
  }
}
